# Copy this file to .env and fill in your values
# cp .env.example .env

# Google Earth Engine project ID (required for live Sentinel-2 extraction)
GEE_PROJECT=your-gee-project-id

# Sentinel-2 acquisition window (use May-June for best olive contrast)
SENTINEL_DATE_START=2024-05-01
SENTINEL_DATE_END=2024-06-30

# Max cloud cover percentage for Sentinel-2 scene selection
SENTINEL_CLOUD_PCT=40

# Maximum polygon area allowed in the live demo (km²)
MAX_POLYGON_KM2=100
